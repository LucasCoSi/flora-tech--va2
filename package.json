{
  "name": "flora-tech-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo FloraTech — Monitoramento de Estufas Hidropônicas",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:backend": "turbo run dev --filter=@flora-tech/backend",
    "dev:frontend": "turbo run dev --filter=@flora-tech/frontend",
    "build:backend": "turbo run build --filter=@flora-tech/backend",
    "build:frontend": "turbo run build --filter=@flora-tech/frontend"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.12.1"
}
